# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
.Python
.venv/
venv/
env/

# ── PyInstaller build output (generated by build.bat) ──────
build/
dist/
*.manifest
*.exe.spec.bak

# ── IDE / OS noise ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Local credentials & user state (NEVER commit) ──────────
# Saved router login is stored under the user's home dir; just in case
# someone copies the .fiberguard folder into the repo, ignore it.
.fiberguard/
*.preflight_passed
config.local.json

# ── Old prototypes + research dumps ────────────────────────
# Kept locally for reference but excluded from the GitHub mirror.
_archive/

# ── Misc ───────────────────────────────────────────────────
*.log
build_output.log
*.tmp

# stray screenshots — but keep README docs and bundled assets
*.png
!shared/assets/*.png
!docs/screenshots/*.png
